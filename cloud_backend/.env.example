# Server Configuration
NODE_ENV=development
PORT=3001
API_VERSION=1.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dr_saathi
DB_USER=dr_saathi_user
DB_PASSWORD=your_secure_password
DB_SSL=false

# Production Database (when deployed)
DATABASE_URL=postgresql://username:password@hostname:port/database_name

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here_at_least_64_characters_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://drsaathi.com,https://app.drsaathi.com

# SMS Configuration (for Nepali SMS services)
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_SENDER_ID=DR_SAATHI

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@drsaathi.com
SMTP_PASS=your_email_password

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=24
BACKUP_RETENTION_DAYS=30

# Monitoring
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret

# Nepal Specific Configuration
DEFAULT_TIMEZONE=Asia/Kathmandu
DEFAULT_CURRENCY=NPR
DEFAULT_LANGUAGE=en

# Cloud Storage (for production)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=dr-saathi-files

# Redis Configuration (for production caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
